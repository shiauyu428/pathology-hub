<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE en-export SYSTEM "http://xml.evernote.com/pub/evernote-export4.dtd">
<en-export export-date="20260611T074010Z" application="Evernote" version="11.9.1">
  <note>
    <title>+Addendum (demo)</title>
    <created>20140708T020014Z</created>
    <updated>20240708T034238Z</updated>
    <note-attributes>
      <author>Elaine huang</author>
    </note-attributes>
    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div style="color:rgb(34, 34, 34);"><span style="font-family: Cambria, serif;"><span style="font-size: 12pt;">[Addendum] (Issued on July 7, 2024)</span></span></div><div><span style="font-family: Cambria, serif;"><span style="font-size: 12pt;">Additional immunostaining shows that the nevus cells are diffusely positive for cyclin D1 throughout the entire depth of the tumor, hinting an aggressive nature according to McKee's Pathology of the Skin, 2012 edition. Close follow-up is strongly recommended.   </span></span></div><div><br/></div><div><br/></div><div><br/></div><div><br/></div><div><br/></div></en-note>      ]]>
    </content>
  </note>
  <note>
    <title>Accurate subtyping cannot be performed on fine-needle aspirations, and may be difficult or unreliable on core needle biopsies</title>
    <created>20231004T135810Z</created>
    <updated>20231004T140307Z</updated>
    <note-attributes>
      <author>Elaine huang</author>
    </note-attributes>
    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div><span style="color:rgb(102, 102, 102);">Accurate subtyping may be difficult or unreliable on core needle biopsies. Therefore, an excisional biopsy is strongly recommended for primary diagnosis.</span></div></en-note>      ]]>
    </content>
  </note>
  <note>
    <title>Aneurysm</title>
    <created>20180714T135349Z</created>
    <updated>20180717T031512Z</updated>
    <note-attributes>
      <author>Elaine huang</author>
      <source>desktop.mac</source>
      <source-url>https://app.expertpath.com/document/abdominal-aortic-aneurysm/d255a836-f9a0-4352-931c-7c620fdd50f2?searchTerm=aneurysm</source-url>
    </note-attributes>
    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div>Aneurysm</div><div><br/></div><div>Microscopic description:</div><div>Section shows atherosclerosis with marked degeneration of media, consistent with aneurysm.</div><div><br/></div><div><br/></div><div><br/></div></en-note>      ]]>
    </content>
  </note>
  <note>
    <title>未命名記事</title>
    <created>20190207T061748Z</created>
    <updated>20190207T061748Z</updated>
    <note-attributes>
      <author>Elaine huang</author>
      <source>desktop.win</source>
      <source-application>evernote.win32</source-application>
    </note-attributes>
    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div>bacterial colonies</div></en-note>      ]]>
    </content>
  </note>
  <note>
    <title>bedsore (necrosis)</title>
    <created>20190207T045220Z</created>
    <updated>20190207T045244Z</updated>
    <note-attributes>
      <author>Elaine huang</author>
      <source>desktop.win</source>
      <source-application>evernote.win32</source-application>
    </note-attributes>
    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div><span style="font-size: 19px; font-family: Gulim;">necrosis.</span></div><div><span style="font-size: 19px; font-family: Gulim;"><br/></span></div><div><span style="font-size: 14pt; font-family: Gulim;">Microscopic description:</span></div><div><span style="font-size: 19px; font-family: Gulim;">Section shows soft tissues featuring liquefactive necrosis </span><span style="font-family: Gulim; font-size: 19px;">with focal PMN infiltration.</span></div></en-note>      ]]>
    </content>
  </note>
  <note>
    <title>未命名記事</title>
    <created>20230104T043447Z</created>
    <updated>20230803T051503Z</updated>
    <note-attributes>
      <author>Elaine huang</author>
      <source>desktop.win</source>
      <source-url>https://journals.lww.com/ajsp/Fulltext/2009/11000/Papillary_Squamous_Cell_Carcinoma_of_the_Head_and.19.aspx</source-url>
      <source-application>evernote.win32</source-application>
    </note-attributes>
    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div><span style="color: rgb(51, 51, 51); font-family: &quot;Fira Sans&quot;, Arial, &quot;Helvetica Neue&quot;, Helvetica, sans-serif; font-size: 16px; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; white-space: normal; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px;">Biopsies often represent only small portions of the tumors.</span></div><div><span style="color: rgb(51, 51, 51); font-family: &quot;Fira Sans&quot;, Arial, &quot;Helvetica Neue&quot;, Helvetica, sans-serif; font-size: 16px; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; white-space: normal; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px;">Furthermore, the assessment of invasion can be difficult or impossible.</span></div></en-note>      ]]>
    </content>
  </note>
  <note>
    <title>Biopsy - 無法排除更壞的地方</title>
    <created>20230907T140838Z</created>
    <updated>20230907T140927Z</updated>
    <note-attributes>
      <author>Elaine huang</author>
    </note-attributes>
    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div>Although the histologic features are consistent with a neurofibroma, given the large size of the lesion clinically, the possibility of an unsampled malignant component cannot be excluded in this limited sample.</div></en-note>      ]]>
    </content>
  </note>
  <note>
    <title>C/W necrotizing fasciitis (no muscle)</title>
    <created>20180830T070847Z</created>
    <updated>20190109T031825Z</updated>
    <note-attributes>
      <author>Elaine huang</author>
      <source>desktop.win</source>
      <source-application>evernote.win32</source-application>
    </note-attributes>
    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div>suppurative inflammation.</div><div><br/></div><div>Microscopic description:</div><div>Section shows skin and soft tissue revealing collections of neutrophils, liquified debris of necrotic cells and edema fluid. Although no skeletal muscle tissue is seen in this specimen, the overall features can be consistent with necrotizing fasciitis. Please correlate clinically.</div></en-note>      ]]>
    </content>
  </note>
  <note>
    <title>Consistent with AVF aneurysm</title>
    <created>20260525T044223Z</created>
    <updated>20260525T044238Z</updated>
    <note-attributes>
      <author>Elaine huang</author>
    </note-attributes>
    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div>Consistent with AVF aneurysm. </div><div><br/></div><div>Microscopic description:</div><div>Section shows thick-walled blood vessel with fibromuscular thickening.</div></en-note>      ]]>
    </content>
  </note>
  <note>
    <title>未命名記事</title>
    <created>20181122T102630Z</created>
    <updated>20251009T043342Z</updated>
    <note-attributes>
      <author>Elaine huang</author>
      <source>desktop.win</source>
      <source-application>evernote.win32</source-application>
    </note-attributes>
    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div>Consistent with hematoma.</div><div><br/></div><div>Microscopic description:</div><div>Blood clots with neutrophilic exudate consistent with hematoma are seen.</div><div><br/></div></en-note>      ]]>
    </content>
  </note>
  <note>
    <title>Consultation 潘競成</title>
    <created>20160301T025544Z</created>
    <updated>20250603T082323Z</updated>
    <note-attributes>
      <author>Elaine huang</author>
    </note-attributes>
    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div>This case is sent to Dr Chin-Chen Pan at Taipei Veterans General Hospital for consultation. His comment is described below. </div><div><br/></div></en-note>      ]]>
    </content>
  </note>
