  <note>
    <title>pheochromocytoma/paraganglioma</title>
    <created>20220630T054535Z</created>
    <updated>20220630T054912Z</updated>
    <note-attributes>
      <author>Elaine huang</author>
      <source>desktop.win</source>
      <source-application>evernote.win32</source-application>
    </note-attributes>
    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div>Please correlate with the image findings and complete</div><div>workup for pheochromocytoma/paraganglioma (e.g. urine VMA,</div><div>dopamine, norepinephrine, epinephrine).</div><div><br/></div></en-note>      ]]>
    </content>
  </note>
