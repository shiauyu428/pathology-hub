  <note>
    <title>Deep portion被橫斷</title>
    <created>20180530T131827Z</created>
    <updated>20180530T131843Z</updated>
    <note-attributes>
      <author>Elaine huang</author>
      <source>desktop.mac</source>
    </note-attributes>
    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div><span style="font-size: 10.000000pt; font-family: 'ArialMT';-en-paragraph:true;" title="Page 14">“The maximum tumor thickness cannot
be determined in this specimen because the deep plane of the biopsy transects the tumor.” 
</span></div></en-note>      ]]>
    </content>
  </note>
