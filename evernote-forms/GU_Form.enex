      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div><span style="font-family: &quot;Microsoft YaHei&quot;;">chronic balanitis with clinical phimosis.</span></div><div><br/></div><div>Microscopic description:</div><div><span style="font-family: &quot;Microsoft YaHei&quot;;">The section reveals scattered lymphocytic </span><span style="line-height: 1.45;">infiltrates associated with vascular engorgement and focal </span><span style="line-height: 1.45;">fibrosis.</span></div></en-note>      ]]>
