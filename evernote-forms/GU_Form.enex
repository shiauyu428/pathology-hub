      <source>desktop.win</source>
      <source-application>evernote.win32</source-application>
    </note-attributes>
    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div>PATHOLOGIC DIAGNOSIS:</div><div>Left internal spermatic vein, high ligation ---</div><div>varicocele.</div><div><br/></div><div>Gross description:</div><div>The specimen consists of a piece of tissue measuring _____ cm.</div><div>All for section.</div><div><br/></div><div>Microscopic description:</div><div>Section shows tortuous and dilated veins with narrowing of the lumens, and invagination of intima.</div><div><br/></div><div><br/></div></en-note>      ]]>
    </content>
  </note>
