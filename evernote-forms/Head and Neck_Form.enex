  <note>
    <title>Fistula, consistent with first branchial cleft anomaly. (type I)</title>
    <created>20180512T033828Z</created>
    <updated>20240115T134541Z</updated>
    <note-attributes>
      <author>Elaine huang</author>
      <source>desktop.win</source>
      <source-application>evernote.win32</source-application>
    </note-attributes>
