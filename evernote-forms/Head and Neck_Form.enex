      <source>desktop.win</source>
      <source-application>evernote.win32</source-application>
    </note-attributes>
    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div>Note: The histologic features suggest infection and toxoplasmic lymphadenitis or other pathogens should be considered first. Correlation with serologic studies is necessary.</div></en-note>      ]]>
