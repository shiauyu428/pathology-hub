      <source>desktop.win</source>
      <source-application>evernote.win32</source-application>
    </note-attributes>
    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div>Acral lentigo.</div><div><br/></div><div><br/></div><div>Microscopic description:</div><div>Section shows marked basal cell hyperpigmentation with slight elongation of rete ridges with melanophages in the dermis.</div><div>    </div></en-note>      ]]>
