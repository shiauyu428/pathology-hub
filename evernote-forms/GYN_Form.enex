      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div>Nabothian cyst.       </div><div><br/></div><div>Microscopic description:    </div><div>Dilated mucin filled cyst lined by flattened mucinous epithelium without atypia.</div></en-note>      ]]>
    </content>
  </note>
  <note>
    <title>no endocervix [noendo]</title>
