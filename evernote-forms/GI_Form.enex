      <author>Elaine huang</author>
      <source>desktop.win</source>
      <source-application>evernote.win32</source-application>
    </note-attributes>
    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div>mild chronic inflammation (see description).</div><div><br/></div><div>Microscopic description:</div><div>Section shows gastric mucosal tissue with mild lymphocytic infiltrate in the lamina propria. No significant inflammation or ulceration is seen in this specimen. Please correlate and re-biopsy if clinically indicated.</div><div><span style="font-size: 10pt;"><span style="color:rgb(34, 34, 34);">No Helicobater Pylori is seen.     </span></span></div><div><br/></div></en-note>      ]]>
    </content>
  </note>
  <note>
    <title>Ulcer+IM+HP</title>
