  <note>
    <title>Candidal esophagitis</title>
    <created>20160901T060833Z</created>
    <updated>20241122T083912Z</updated>
    <note-attributes>
      <author>Elaine huang</author>
    </note-attributes>
    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div style="text-align:start;"><span style="font-family: arial;"><span style="font-size: 9pt;"><span style="color:rgb(34, 34, 34);">Candidal esophagitis</span></span></span></div><div><br/></div><div><span style="font-family: arial;"><span style="font-size: 9pt;"><span style="color:rgb(34, 34, 34);">Microscopic description:</span></span></span></div><div style="text-align:start;color:rgb(34, 34, 34);"><span style="font-family: arial, sans-serif;"><span style="font-size: 13px;">Section shows esophageal tissue with ulceration and mixed inflammatory infiltrate. Necrotic debris admixed with abundant fungal spores and hyphae are also seen. No malignancy is observed.</span></span></div><div><br/></div></en-note>      ]]>
    </content>
  </note>
  <note>
