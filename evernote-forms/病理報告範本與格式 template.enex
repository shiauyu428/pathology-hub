  <note>
    <title>Breast_gynecomastia</title>
    <created>20150723T234753Z</created>
    <updated>20260427T032005Z</updated>
    <note-attributes>
      <author>Elaine huang</author>
    </note-attributes>
    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
